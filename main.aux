\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Comparison of regular graphs and hypergraphs. In (a), each edge connects exactly two vertices, representing pairwise correlations. In (b), the dashed ellipse represents a hyperedge connecting three vertices, capturing genuine tripartite entanglement. Hyperedge connects $>2$ vertices and represents genuine multipartite correlations.}}{18}{figure.20}\protected@file@percent }
\newlabel{fig:hypergraph-basic}{{20}{18}{Comparison of regular graphs and hypergraphs. In (a), each edge connects exactly two vertices, representing pairwise correlations. In (b), the dashed ellipse represents a hyperedge connecting three vertices, capturing genuine tripartite entanglement. Hyperedge connects $>2$ vertices and represents genuine multipartite correlations}{figure.20}{}}
\newlabel{fig:hypergraph-basic@cref}{{[figure][20][]20}{[1][18][]18}}
