\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Reading stabilizer generators from the graph structure. For each vertex $i$, the stabilizer generator $K_i$ is the product of $X$ on vertex $i$ and $Z$ on all its neighbors. These $N$ operators generate the full stabilizer group of $2^N$ elements. For vertex $i$: $K_i = X_i \DOTSB \prod@ \slimits@ _{j \in N(i)} Z_j$, where $N(i)$ is the set of neighbors of $i$. The stabilizer group is $\mathcal  {S} = \langle K_1, K_2, \ldots  , K_N \rangle $.}}{17}{figure.18}\protected@file@percent }
\newlabel{fig:stabilizer-generators}{{18}{17}{Reading stabilizer generators from the graph structure. For each vertex $i$, the stabilizer generator $K_i$ is the product of $X$ on vertex $i$ and $Z$ on all its neighbors. These $N$ operators generate the full stabilizer group of $2^N$ elements. For vertex $i$: $K_i = X_i \prod _{j \in N(i)} Z_j$, where $N(i)$ is the set of neighbors of $i$. The stabilizer group is $\mathcal {S} = \langle K_1, K_2, \ldots , K_N \rangle $}{figure.18}{}}
\newlabel{fig:stabilizer-generators@cref}{{[figure][18][]18}{[1][16][]17}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Different graph representations of the GHZ state. The GHZ state can be represented as a path graph, cycle graph, or other connected structures, all of which are locally complemented to each other and thus share equivalent entanglement properties. GHZ state equivalence: $|\text  {GHZ}_N\rangle = \frac  {1}{\sqrt  {2}}(|0\rangle ^{\otimes N} + |1\rangle ^{\otimes N})$ can be represented by different graph structures that are LC-equivalent (connected through local complementations).}}{17}{figure.19}\protected@file@percent }
\newlabel{fig:ghz-graph-equivalence}{{19}{17}{Different graph representations of the GHZ state. The GHZ state can be represented as a path graph, cycle graph, or other connected structures, all of which are locally complemented to each other and thus share equivalent entanglement properties. GHZ state equivalence: $|\text {GHZ}_N\rangle = \frac {1}{\sqrt {2}}(|0\rangle ^{\otimes N} + |1\rangle ^{\otimes N})$ can be represented by different graph structures that are LC-equivalent (connected through local complementations)}{figure.19}{}}
\newlabel{fig:ghz-graph-equivalence@cref}{{[figure][19][]19}{[1][16][]17}}
\citation{Hikihara2024}
