\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Three-qubit GHZ state $(|000\rangle + |111\rangle )/\sqrt  {2}$ in Dimensional Circular Notation. This state exhibits genuine multipartite entanglement---all three qubits are entangled such that measuring any one qubit determines the state of the other two. The DCN cube shows non-zero amplitudes only at opposite corners, requiring the full 3D structure.}}{6}{figure.5}\protected@file@percent }
\newlabel{fig:dcn-3qubit-ghz}{{5}{6}{Three-qubit GHZ state $(|000\rangle + |111\rangle )/\sqrt {2}$ in Dimensional Circular Notation. This state exhibits genuine multipartite entanglement---all three qubits are entangled such that measuring any one qubit determines the state of the other two. The DCN cube shows non-zero amplitudes only at opposite corners, requiring the full 3D structure}{figure.5}{}}
\newlabel{fig:dcn-3qubit-ghz@cref}{{[figure][5][]5}{[1][5][]6}}
