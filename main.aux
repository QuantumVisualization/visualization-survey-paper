\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces GHZ state representation: (a) Complete graph $K_4$ requires many pairwise edges. (b) GHZ hypergraph represents the same state with a single hyperedge connecting all $N$ qubits, capturing the genuine N-partite entanglement. Single hyperedge captures $|GHZ_N\rangle = \frac  {1}{\sqrt  {2}}(|0\rangle ^{\otimes N}+|1\rangle ^{\otimes N})$.}}{19}{figure.21}\protected@file@percent }
\newlabel{fig:ghz-hypergraph}{{21}{19}{GHZ state representation: (a) Complete graph $K_4$ requires many pairwise edges. (b) GHZ hypergraph represents the same state with a single hyperedge connecting all $N$ qubits, capturing the genuine N-partite entanglement. Single hyperedge captures $|GHZ_N\rangle = \frac {1}{\sqrt {2}}(|0\rangle ^{\otimes N}+|1\rangle ^{\otimes N})$}{figure.21}{}}
\newlabel{fig:ghz-hypergraph@cref}{{[figure][21][]21}{[1][18][]19}}
\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces Lattice hypergraph structure showing hierarchical levels. Different hyperedge sizes (2, 3, 4, N) capture correlations at different scales. The full lattice hypergraph combines all levels for complete characterization of multipartite entanglement. Lattice hypergraph: hierarchical levels of hyperedges capture different types of multipartite correlations at different scales.}}{19}{figure.22}\protected@file@percent }
\newlabel{fig:lattice-hypergraph}{{22}{19}{Lattice hypergraph structure showing hierarchical levels. Different hyperedge sizes (2, 3, 4, N) capture correlations at different scales. The full lattice hypergraph combines all levels for complete characterization of multipartite entanglement. Lattice hypergraph: hierarchical levels of hyperedges capture different types of multipartite correlations at different scales}{figure.22}{}}
\newlabel{fig:lattice-hypergraph@cref}{{[figure][22][]22}{[1][18][]19}}
