\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Illustration of local complementation on a graph state. When LC is applied to vertex $b$, an edge is added between its neighbors $a$ and $c$. States related by LC (and edge additions/deletions) have equivalent entanglement structure. Local Complementation (LC): Applying LC on vertex $v$ adds edges between all pairs of neighbors of $v$ that weren't previously connected.}}{16}{figure.17}\protected@file@percent }
\newlabel{fig:local-complementation}{{17}{16}{Illustration of local complementation on a graph state. When LC is applied to vertex $b$, an edge is added between its neighbors $a$ and $c$. States related by LC (and edge additions/deletions) have equivalent entanglement structure. Local Complementation (LC): Applying LC on vertex $v$ adds edges between all pairs of neighbors of $v$ that weren't previously connected}{figure.17}{}}
\newlabel{fig:local-complementation@cref}{{[figure][17][]17}{[1][16][]16}}
