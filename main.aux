\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Hypertree representation of multipartite entanglement. Each node represents a bipartition of the system, and edge weights quantify the entanglement across that cut. This hierarchical structure reveals the nesting of entanglement in tensor network states. Hypertree Structure: Nodes = bipartitions, Edge weight = entanglement $w = E(|\psi \rangle _{A|B})$.}}{11}{figure.11}\protected@file@percent }
\newlabel{fig:hypertree}{{11}{11}{Hypertree representation of multipartite entanglement. Each node represents a bipartition of the system, and edge weights quantify the entanglement across that cut. This hierarchical structure reveals the nesting of entanglement in tensor network states. Hypertree Structure: Nodes = bipartitions, Edge weight = entanglement $w = E(|\psi \rangle _{A|B})$}{figure.11}{}}
\newlabel{fig:hypertree@cref}{{[figure][11][]11}{[1][10][]11}}
